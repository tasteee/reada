{
  "name": "reada",
  "version": "1.0.0",
  "description": "Insanely simple, DX focused React state management.",
  "homepage": "https://github.com/tasteee/reada#readme",
  "type": "module",
  "main": "./dist/reada.cjs",
  "module": "./dist/reada.esm.js",
  "jsdelivr": "./dist/reada.iife.js",
  "types": "./dist/reada.d.ts",
  "exports": {
    ".": {
      "require": "./dist/reada.cjs",
      "import": "./dist/reada.esm.js",
      "types": "./dist/reada.d.ts"
    }
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/reada.d.ts"
      ]
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md",
    "package.json"
  ],
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "postbuild": "dts-bundle-generator --verbose ./src/index.ts -o ./dist/reada.d.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "format": "prettier . --write",
    "upgrade": "upgradeps",
    "release": "npm run build && np"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.5.0",
    "@types/react": "^18.0.0 || ^19.0.0",
    "@types/react-dom": "^18.0.0 || ^19.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "dts-bundle-generator": "^9.5.1",
    "jsdom": "^24.1.1",
    "lint-staged": "^15.2.9",
    "np": "^10.0.6",
    "prettier": "^3.3.3",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "terser": "^5.31.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "upgradeps": "^2.0.6",
    "vite": "^5.0.12",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "just-safe-get": "^4.2.0",
    "just-safe-set": "^4.2.1"
  },
  "author": {
    "name": "rokki",
    "email": "rokkicolcleasure@gmail.com",
    "url": "https://github.com/tasteee"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tasteee/reada.git"
  },
  "bugs": {
    "url": "https://github.com/tasteee/reada/issues"
  },
  "license": "MIT",
  "private": false,
  "sponsor": {
    "url": "https://x.com/ken_wheeler"
  },
  "funding": [
    {
      "type": "individual",
      "url": "https://support.example.com"
    }
  ],
  "keywords": [
    "react",
    "state management",
    "zustand",
    "redux",
    "reada",
    "store",
    "reactive",
    "state",
    "harambe"
  ]
}
